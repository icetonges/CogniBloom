// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ AUTHENTICATION & USERS ============

model User {
  id                    String      @id @default(cuid())
  email                 String      @unique
  name                  String
  role                  UserRole    @default(STUDENT)

  // Profile
  grade                 Int?
  age                   Int?
  learningStyle         String?
  interests             String[]    @default([])

  // Auth — clerkId removed (single-user app, no OAuth)
  emailVerified        Boolean     @default(false)

  // Relationships
  parentId             String?
  parent               User?       @relation("ParentChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children             User[]      @relation("ParentChildren")

  sessions             TutorSession[]
  notes                Note[]
  uploads              Upload[]
  quizzes              Quiz[]
  flashcards           Flashcard[]
  subscriptions        Subscription[]
  preferences          UserPreferences?
  learningProfile      LearningProfile?

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  lastActiveAt         DateTime    @default(now())

  @@index([email])
  @@index([parentId])
}

enum UserRole {
  STUDENT
  PARENT
  ADMIN
}

model UserPreferences {
  id                    String      @id @default(cuid())
  userId                String      @unique
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  preferredTutorMode    TutorMode   @default(GENERAL)
  preferredModel        String      @default("gemini-2.5-flash")
  responseLength        String      @default("medium")
  includeExamples       Boolean     @default(true)
  includeVisuals        Boolean     @default(true)

  // Profile prefs
  grade                 String      @default("Year 9")
  subjects              String[]    @default([])

  emailFrequency        String      @default("daily")
  pushNotifications     Boolean     @default(true)

  darkMode              Boolean     @default(false)
  fontSize              String      @default("medium")

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

enum TutorMode {
  GENERAL
  MATH
  CODING
  LANGUAGE
  SCIENCE
  HOMEWORK_HELPER
  SOCRATIC_COACH
  QUIZ
}

// ============ LEARNING PROFILE & ANALYTICS ============

model LearningProfile {
  id                    String      @id @default(cuid())
  userId                String      @unique
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  masteryScores        Json        @default("{}")
  weakAreas            String[]    @default([])
  strongAreas          String[]    @default([])

  totalLessonsCompleted Int       @default(0)
  totalPracticeAnswered Int       @default(0)
  averageAccuracy      Float      @default(0.0)
  currentStreak        Int        @default(0)
  longestStreak        Int        @default(0)

  // Gamification
  xp                   Int        @default(0)
  level                Int        @default(1)

  recentTopics         String[]    @default([])
  recommendedTopics    String[]    @default([])

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

// ============ GAMIFICATION ============

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  @@unique([userId, badgeId])
  @@index([userId])
}

// ============ NOTES & JOURNALING ============

model Note {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  title                 String
  content               String      @db.Text   // rich HTML (TipTap output)
  contentFormat         String      @default("html")  // "html" | "markdown" (legacy)

  hasMath              Boolean     @default(false)
  hasCode              Boolean     @default(false)
  hasImages            Boolean     @default(false)

  tags                 String[]    @default([])
  subject              String?

  isPublic             Boolean     @default(false)
  isBookmarked         Boolean     @default(false)

  slug                 String?     @unique    // "20260523-amc-math-047" — immutable after creation
  subjectIndex         Int?                   // sequential per subject: 1, 2, 3...

  // AI Expert Tutor analysis (generated async after save)
  mindMap              String?     @db.Text   // JSON: { label, children[] } tree
  reasoningHints       String?     @db.Text   // JSON: { step, hint }[]
  knowledgePoints      String?     @db.Text   // JSON: { term, definition, importance }[]
  tutorSummary         String?     @db.Text   // HTML: teacher's expert notes
  aiAnalyzedAt         DateTime?              // when analysis last ran

  // Published web page
  publishedHtml        String?     @db.Text   // self-contained HTML page
  publishedSlug        String?     @unique    // e.g. "20260522_AMC_Math_001"
  publishedAt          DateTime?

  // pgvector embedding (768 dims — Google text-embedding-004)
  embedding            Unsupported("vector(768)")?

  uploads              Upload[]
  reviews              NoteReview[]
  flashcards           Flashcard[]

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@index([publishedSlug])
  @@index([slug])
  @@index([subject])
  @@index([userId, createdAt])
}

model NoteReview {
  id                    String      @id @default(cuid())
  noteId                String
  note                  Note        @relation(fields: [noteId], references: [id], onDelete: Cascade)

  summary              String      @db.Text
  keyPoints            String[]
  weakAreas            String[]
  masteryEstimate      Float
  recommendations      String[]    @db.Text

  createdAt            DateTime    @default(now())
}

// ============ FILE UPLOADS & STORAGE ============

model Upload {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  filename              String
  mimeType              String
  fileSize              Int
  fileType              String

  r2Url                String      @unique
  signedUrl            String?
  signedUrlExpiry      DateTime?

  status               String      @default("pending")
  processingError      String?

  extractedText        String?     @db.Text
  extractedMetadata    Json?
  chunks              Chunk[]
  figures             FigureEmbedding[]

  noteId              String?
  note                Note?       @relation(fields: [noteId], references: [id], onDelete: SetNull)

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

model Chunk {
  id                   String      @id @default(cuid())
  uploadId            String
  upload              Upload      @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  chunkIndex          Int
  content             String      @db.Text
  /// Wider surrounding sentence window — used in LLM prompt context (sentence-window RAG)
  windowContent       String?     @db.Text
  embedding           Unsupported("vector(768)")?

  startPage           Int?
  endPage             Int?

  @@unique([uploadId, chunkIndex])
  @@index([uploadId])
}

// ============ MULTIMODAL / FIGURE EMBEDDINGS ============

/// One entry per PDF page that contains a figure/diagram/shape.
/// CLIP embedding (512-dim) allows visual similarity search:
///   - student query text → CLIP text encode → cosine search → finds matching page image
///   - retrieved page image (base64) → passed to Gemini Vision as visual context
model FigureEmbedding {
  id           String   @id @default(cuid())
  uploadId     String
  upload       Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  pageIndex    Int      // 0-based page number in the source PDF
  imageBase64  String   @db.Text // PNG rendered at 150 DPI, base64-encoded
  caption      String?  @db.Text // Gemini's [FIGURE: ...] description for this page
  width        Int?
  height       Int?

  /// CLIP vector(512) — same space as CLIP text encoding of queries
  embedding    Unsupported("vector(512)")?

  createdAt    DateTime @default(now())

  @@index([uploadId])
  @@index([pageIndex])
}

// ============ RAG EVALUATION ============

/// RAGAS-inspired retrieval quality metrics captured after each tutor response.
model RagEvaluation {
  id                  String      @id @default(cuid())
  userId              String
  sessionId           String
  query               String      @db.Text
  response            String      @db.Text

  /// Fraction of response claims grounded in the retrieved context (0–1)
  faithfulness        Float?
  /// How relevant the response is to the query (0–1)
  answerRelevancy     Float?
  /// How well the retrieved context covers what was needed (0–1)
  contextPrecision    Float?
  /// Whether any context was retrieved at all
  ragUsed             Boolean     @default(false)
  notesRetrieved      Int         @default(0)
  chunksRetrieved     Int         @default(0)
  hydeUsed            Boolean     @default(false)

  createdAt           DateTime    @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

// ============ TUTOR SESSIONS & CONVERSATIONS ============

model TutorSession {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  mode                  TutorMode   @default(GENERAL)
  topic                 String?
  difficulty            String      @default("adaptive")

  messages              TutorMessage[]

  aiProvider            String
  aiModel              String

  messageCount         Int         @default(0)
  totalTokensUsed      Int         @default(0)
  averageResponseTime  Float       @default(0.0)

  studentRating        Int?
  feedback             String?

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  endedAt              DateTime?

  @@index([userId])
  @@index([createdAt])
}

model TutorMessage {
  id                    String      @id @default(cuid())
  sessionId             String
  session               TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  role                  String      @default("user")
  content              String      @db.Text

  fileUrl              String?
  imageUrl             String?
  codeLanguage         String?

  citations            Citation[]
  sources              String[]    @default([])

  tokensUsed           Int         @default(0)
  processingTime       Int         @default(0)

  createdAt            DateTime    @default(now())

  @@index([sessionId])
}

model Citation {
  id                    String      @id @default(cuid())
  messageId             String
  message               TutorMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  title                String
  url                  String
  source               String
  trustScore           Float       @default(0.8)

  @@index([messageId])
}

// ============ QUIZZES & PRACTICE ============

model Quiz {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  title                String
  description          String?
  subject              String
  difficulty           String

  questions            Question[]

  isAiGenerated        Boolean     @default(false)
  generatedFromTopic   String?

  score                Float?
  totalQuestions      Int
  correctAnswers      Int         @default(0)
  timeSpent           Int?

  status              String      @default("draft")

  createdAt           DateTime    @default(now())
  completedAt         DateTime?

  @@index([userId])
}

model Question {
  id                   String      @id @default(cuid())
  quizId              String
  quiz                Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)

  questionIndex       Int
  type                String      @default("multiple_choice")

  question            String      @db.Text
  questionRichContent String?     @db.Text

  options             Option[]

  studentAnswer       String?     @db.Text
  correctAnswer       String      @db.Text
  explanation         String?     @db.Text

  isCorrect           Boolean?
  score               Float?
  aiGradingRubric    String?     @db.Text

  @@unique([quizId, questionIndex])
}

model Option {
  id                   String      @id @default(cuid())
  questionId          String
  question            Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  optionIndex         Int
  text                String      @db.Text
  isCorrect           Boolean

  @@unique([questionId, optionIndex])
}

// ============ FLASHCARDS & SPACED REPETITION ============

model Flashcard {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Source
  noteId                String?
  note                  Note?       @relation(fields: [noteId], references: [id], onDelete: SetNull)

  // Content
  front                 String      @db.Text  // question / term
  back                  String      @db.Text  // answer / definition
  subject               String?
  tags                  String[]    @default([])

  // SM-2 Spaced Repetition fields
  easeFactor            Float       @default(2.5)   // difficulty multiplier
  interval              Int         @default(0)      // days until next review
  repetitions           Int         @default(0)      // times reviewed successfully
  nextReviewAt          DateTime    @default(now())  // when to show next

  // Stats
  totalReviews          Int         @default(0)
  correctReviews        Int         @default(0)

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  reviews               FlashcardReview[]

  @@index([userId])
  @@index([nextReviewAt])
  @@index([noteId])
}

model FlashcardReview {
  id                    String      @id @default(cuid())
  flashcardId           String
  flashcard             Flashcard   @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  // Rating 0-5 (SM-2 standard: 0=blackout, 3=correct with effort, 5=perfect)
  rating                Int
  previousInterval      Int
  previousEaseFactor    Float
  newInterval           Int
  newEaseFactor         Float

  reviewedAt            DateTime    @default(now())

  @@index([flashcardId])
}

// ============ KNOWLEDGE & MASTERY ============

model KnowledgePoint {
  id                    String      @id @default(cuid())

  title                String
  description          String?
  subject              String
  gradeLevel           Int[]

  prerequisites        String[]    @default([])
  relatedTopics        String[]    @default([])

  explanation          String      @db.Text
  examples             String[]
  practiceQuestions    String[]

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([subject])
  @@index([gradeLevel])
}

// ============ MULTI-SOURCE CATEGORY FEED ============

/// Tracks every external source (RSS feed, public API, or AI generator)
/// that supplies content for a learning category.
model FeedSource {
  id           String             @id @default(cuid())
  name         String             // "Hacker News", "NASA APOD", "arXiv Math"
  category     String             // "coding", "science", "math", …
  url          String             @default("")  // "" for AI-only sources
  type         String             // "rss" | "api" | "ai"
  isActive     Boolean            @default(true)
  lastPulledAt DateTime?
  lastStatus   String?            // "success" | "error" | "skipped"
  lastError    String?            @db.Text
  itemsToday   Int                @default(0)
  itemsTotal   Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  items        CategoryFeedItem[]

  @@index([category])
}

/// One learning card from any category feed source.
/// Stores real pulled content (RSS/API) or AI-generated content.
model CategoryFeedItem {
  id               String      @id @default(cuid())
  category         String      // "math" | "coding" | "science" | …
  sourceId         String?
  source           FeedSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  sourceName       String?     // denormalised for fast display
  title            String
  summary          String      @db.Text
  body             String?     @db.Text  // full content when available
  url              String?               // link to original article / video
  imageUrl         String?
  emoji            String      @default("📚")
  tags             String[]    @default([])
  difficulty       String      @default("medium")
  estimatedMinutes Int         @default(3)
  contentType      String      @default("article") // article | video | puzzle | challenge | tip
  author           String?
  publishedAt      DateTime?
  isAiGenerated    Boolean     @default(false)
  expiresAt        DateTime
  createdAt        DateTime    @default(now())

  @@index([category, createdAt])
  @@index([expiresAt])
}

// ============ DAILY FEED & CONTENT ============

model DailyFeedItem {
  id                    String      @id @default(cuid())

  type                  String
  title                String
  description          String      @db.Text
  content              String      @db.Text

  subject              String
  difficulty           String
  gradeLevel           Int[]
  estimatedTime        Int

  isAiGenerated        Boolean     @default(false)
  sourceUrl            String?
  credibility          Float       @default(0.8)

  createdAt            DateTime    @default(now())
  expiresAt            DateTime    @default(now())

  @@index([gradeLevel])
  @@index([expiresAt])
}

model FeedEngagement {
  id                    String      @id @default(cuid())
  userId                String
  itemId                String

  isRead                Boolean     @default(false)
  isBookmarked          Boolean     @default(false)
  timeSpent             Int?
  completed             Boolean     @default(false)

  createdAt             DateTime    @default(now())

  @@unique([userId, itemId])
}

// ============ REPORTING & ANALYTICS ============

model DailyReport {
  id                    String      @id @default(cuid())
  userId                String

  reportDate            DateTime

  notesCreated         Int
  sessionsCompleted    Int
  quizzesTaken         Int
  practiceTime         Int

  topicsFocused        String[]
  masteryGains         Json
  averageSessionScore  Float

  recommendedTopics    String[]
  focusAreas           String[]

  emailSentAt          DateTime?

  createdAt            DateTime    @default(now())

  @@unique([userId, reportDate])
}

// ============ SUBSCRIPTIONS & BILLING ============

model Subscription {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId      String      @unique
  stripeSubscriptionId  String?     @unique

  plan                  SubscriptionPlan  @default(FREE)

  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean     @default(false)
  cancelledAt           DateTime?

  monthlyQuota          Int
  usedThisMonth         Int         @default(0)

  status                String      @default("active")

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([userId])
}

enum SubscriptionPlan {
  FREE
  PLUS
  PREMIUM
}

// ============ AUDIT & LOGGING ============

model AuditLog {
  id                    String      @id @default(cuid())
  userId                String

  action                String
  resource              String
  resourceId            String?

  changes               Json
  ipAddress             String?
  userAgent             String?

  createdAt             DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AiUsageLog {
  id                    String      @id @default(cuid())
  userId                String

  provider              String
  model                 String

  inputTokens           Int
  outputTokens          Int
  totalTokens           Int

  estimatedCost         Float

  useCase               String

  createdAt             DateTime    @default(now())

  @@index([userId])
  @@index([provider])
}
